<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.account.tax.return.start.date</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='account_tax_periodicity']" position="after">
                <setting id="tax_periodicity_start_date" string="Tax Return Start Date" help="Set the date from which tax returns should start being generated.">
                    <field name="account_tax_periodicity_start_date"/>
                    <div class="mt8">
                        <button name="open_tax_report_start_dates" icon="oi-arrow-right" type="object" string="Configure start dates" class="btn-link"/>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>

    <!-- Popup form to edit start date -->
    <record id="res_company_tax_start_date_form" model="ir.ui.view">
        <field name="name">res.company.tax.start.date.form</field>
        <field name="model">res.company</field>
        <field name="arch" type="xml">
            <form string="Tax Return Start Date Configuration">
                <group>
                    <field name="name" readonly="1"/>
                    <field name="account_tax_periodicity_start_date" 
                           string="Tax Return Start Date"
                           help="All tax reports will use this start date for period calculations"/>
                </group>
                <footer>
                    <button string="Save" class="btn-primary" special="save"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
